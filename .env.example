# Comunidad de Psicologia - environment template
#
# Use the same variable names in every environment. Only the values change.
# Variables prefixed with `NEXT_PUBLIC_` are exposed to the browser.
# Never put secrets in `NEXT_PUBLIC_*`.
# Server-only secrets in this file include:
# - SUPABASE_SERVICE_ROLE_KEY
# - STRIPE_SECRET_KEY
# - STRIPE_WEBHOOK_SECRET
# - RESEND_API_KEY
# - ONESIGNAL_REST_API_KEY
# - AI_API_KEY

# =================================
# CORE APP
# =================================
# Required to run the base app in local, staging, and production.
# This value changes between staging and production.
NEXT_PUBLIC_APP_URL=https://<set-app-origin-per-environment>
# Required for protected Vercel Cron endpoints.
CRON_SECRET=<set-random-cron-secret>
# Growth rewards are off by default unless explicitly enabled.
ENABLE_GROWTH_REWARDS=false
ENABLE_GROWTH_STRIPE_DISCOUNTS=false
ENABLE_GROWTH_STRIPE_UPGRADES=false
ENABLE_GROWTH_REWARD_CRON=false
ENABLE_GROWTH_ADVANCED_PROGRAMS=false
# Optional: used for WhatsApp support CTAs inside the app.
# Example: https://wa.me/5215512345678
NEXT_PUBLIC_SUPPORT_WHATSAPP_URL=

# =================================
# ANALYTICS, CONSENT, TAG MANAGER
# =================================
# Required to enable the privacy-first tracking runtime on public marketing pages.
# `NEXT_PUBLIC_*` values are safe to expose in the browser.
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=<set-gtm-container-id>
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=<set-google-search-console-verification-token>

# Optional but recommended if you want server-side GA4 confirmation for
# `generate_lead` and `purchase`.
GA4_MEASUREMENT_ID=<set-ga4-measurement-id>
GA4_API_SECRET=<set-ga4-measurement-protocol-api-secret>

# Optional: enable Meta Conversions API for server-side `generate_lead` and `purchase`.
ENABLE_META_SERVER_TRACKING=false
META_PIXEL_ID=<set-meta-pixel-id>
META_CAPI_ACCESS_TOKEN=<set-meta-capi-access-token>
META_TEST_EVENT_CODE=

# Optional: enable TikTok Events API for server-side `generate_lead` and `purchase`.
# Delivered disabled by default.
ENABLE_TIKTOK_SERVER_TRACKING=false
TIKTOK_PIXEL_ID=<set-tiktok-pixel-id>
TIKTOK_ACCESS_TOKEN=<set-tiktok-events-api-access-token>
TIKTOK_TEST_EVENT_CODE=

# =================================
# SUPABASE
# =================================
# Required to run the base app.
# These values change between staging and production.
NEXT_PUBLIC_SUPABASE_URL=https://<set-supabase-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<set-supabase-publishable-or-legacy-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<set-supabase-secret-or-legacy-service-role-key>

# =================================
# STRIPE
# =================================
# Optional by feature: required only if billing, checkout, portal, or webhooks
# are enabled in this environment.
# These values change between staging and production.
# Only `NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY` may reach the client.
STRIPE_SECRET_KEY=<set-stripe-server-secret-key>
STRIPE_WEBHOOK_SECRET=<set-stripe-webhook-signing-secret>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<set-stripe-publishable-key>
STRIPE_PRICE_LEVEL_1_MONTHLY=<set-stripe-price-id>
STRIPE_PRICE_LEVEL_1_ANNUAL=<set-stripe-price-id>
STRIPE_PRICE_LEVEL_2_MONTHLY=<set-stripe-price-id>
STRIPE_PRICE_LEVEL_2_ANNUAL=<set-stripe-price-id>
# Optional but required if you plan to sell multiple active level-2 specializations.
# Example keys:
# STRIPE_PRICE_LEVEL_2_CLINICA_MONTHLY=<set-stripe-price-id>
# STRIPE_PRICE_LEVEL_2_CLINICA_ANNUAL=<set-stripe-price-id>
STRIPE_PRICE_LEVEL_3_MONTHLY=<set-stripe-price-id>
STRIPE_PRICE_LEVEL_3_ANNUAL=<set-stripe-price-id>

# =================================
# EMAIL
# =================================
# Optional by feature: required only if transactional emails are enabled.
# This value changes between staging and production.
# Never expose this value to the client.
RESEND_API_KEY=<set-resend-server-api-key>
# Must be a verified Resend sender, for example:
# RESEND_FROM_EMAIL=SAPIHUM <notificaciones@yourdomain.com>
RESEND_FROM_EMAIL=<set-resend-verified-sender>
# Internal inbox for operational alerts about leads, purchases and failures.
ADMIN_NOTIFY_EMAIL=<set-admin-alert-recipient>

# =================================
# ONESIGNAL
# =================================
# Optional by feature: required only if browser push notifications are enabled.
# These values change between staging and production.
# Only `NEXT_PUBLIC_ONESIGNAL_APP_ID` may reach the browser.
NEXT_PUBLIC_ONESIGNAL_APP_ID=<set-onesignal-app-id>
ONESIGNAL_REST_API_KEY=<set-onesignal-rest-api-key>

# =================================
# CALENDAR SYNC
# =================================
# Optional by feature: required only if Google Calendar connection and
# external busy-slot detection are enabled in this environment.
# `GOOGLE_CALENDAR_REDIRECT_URI` is optional; if omitted, the app uses
# `${NEXT_PUBLIC_APP_URL}/api/calendar/google/callback`.
GOOGLE_CALENDAR_CLIENT_ID=<set-google-oauth-client-id>
GOOGLE_CALENDAR_CLIENT_SECRET=<set-google-oauth-client-secret>
GOOGLE_CALENDAR_REDIRECT_URI=

# =================================
# AI
# =================================
# Optional by feature: required only if AI transcription / SOAP generation is enabled.
# These values can differ between staging and production.
# `AI_API_KEY` must stay server-only.
# The current transcription flow uses a Groq-compatible API key.
AI_PROVIDER=groq
AI_API_KEY=<set-ai-server-api-key>
AI_MODEL_NAME=llama-3.1-70b-versatile

# =================================
# TESTING
# =================================
# Optional: local / CI only. Do not use these for application runtime in
# staging or production.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_WEB_SERVER_COMMAND=npm run dev -- --hostname 127.0.0.1 --port 3000
PLAYWRIGHT_SKIP_WEB_SERVER=
PLAYWRIGHT_STORAGE_STATE_DIR=tests/.auth

# =================================
# RATE LIMITING — UPSTASH REDIS
# =================================
# Required for rate limiting on POST API endpoints before campaigns.
# Protects: /api/leads/capture, /api/leads/founders,
#           /api/payments/checkout, /api/payments/subscribe, /api/payments/cancel
#
# Setup:
#   1. Go to https://console.upstash.com/ and create a Redis database
#      (free tier handles ~10k req/day — enough for early traction)
#   2. Choose a region close to your Vercel deployment (us-east-1 recommended)
#   3. Copy "REST URL" and "REST Token" from the database details page
#   4. Set them here AND in Vercel Dashboard → Settings → Environment Variables
#
# Behavior when these vars are missing:
#   - Development  → request allowed through, warning logged to console
#   - Production   → request allowed through, error logged to console (configure before launch!)
#
# Both vars are server-only — never prefix with NEXT_PUBLIC_.
UPSTASH_REDIS_REST_URL=<set-upstash-redis-rest-url>
UPSTASH_REDIS_REST_TOKEN=<set-upstash-redis-rest-token>

# =================================
# SPEAKER COMMERCE MVP
# =================================
# Enables speaker attribution links, commission snapshots, and payout requests.
ENABLE_SPEAKER_COMMERCE_ENGINE=false
ENABLE_SPEAKER_PAYOUT_REQUESTS=false
